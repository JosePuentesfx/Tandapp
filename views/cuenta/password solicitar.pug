include ../layout/header.pug
block content
  main.min-h-screen.bg-gray-50.flex.items-center.justify-center.px-4.py-10

    div(class="w-full max-w-md")
      .mb-6
        a(href="/cuenta" class="text-sm text-gray-400 hover:underline") ← Volver a Mi Cuenta
        h1.text-2xl.font-bold.text-gray-900.mt-2 Cambiar contraseña
        p.text-sm.text-gray-500.mt-1 Te enviaremos un código de verificación a tu correo

      if error && error.length
        .mb-5.px-4.py-3.rounded-2xl.text-sm.font-medium.flex.items-center.gap-2(style="background:#fee2e2;color:#991b1b;border:1px solid #fecaca")
          svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12")
          span= error[0]

      .bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-8

        //- Ícono
        .flex.justify-center.mb-6
          .h-16.w-16.rounded-2xl.flex.items-center.justify-center(style="background:#fef3c7")
            svg(xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" style="color:#d97706" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")

        h2.text-base.font-semibold.text-gray-900.text-center.mb-1 Verificación por correo
        p.text-sm.text-gray-500.text-center.mb-6
          | Enviaremos un código de 6 dígitos a:
          br
          strong.text-gray-700= user.email

        form(action="/cuenta/password/solicitar" method="POST")
          button(
            type="submit"
            class="w-full py-3 rounded-xl text-sm font-semibold text-white transition-opacity hover:opacity-90 active:opacity-80"
            style="background:#1a7a4a"
          )
            | Enviar código →
        
        p.text-xs.text-gray-400.text-center.mt-4 El código expira en 10 minutos
