include ../layout/header.pug
include ../layout/sidebaradmin.pug 
block content
  main.min-h-screen.bg-gray-50(class="ml-0 md:ml-64 pt-24 px-6 pb-8")

    //- ── HEADER ─────────────────────────────────────────
    .flex.items-center.justify-between.mb-6
      div
        .flex.items-center.gap-2.mb-1
          span.text-xs.font-semibold.px-2.py-1.rounded-full(style="background:#fef3c7; color:#92400e") Panel Admin
          a(href="/admin" class="text-xs text-gray-400 hover:underline") ← Volver al dashboard
        h1.text-2xl.font-bold.text-gray-900 Usuarios
        p.text-sm.text-gray-500.mt-1 Gestiona los usuarios registrados en TandaApp

      //- Contador
      .text-right
        p.text-2xl.font-bold.text-gray-900= usuarios ? usuarios.length : 0
        p.text-xs.text-gray-400 usuarios registrados

    //- Flash messages
    if success && success.length
      .mb-5.px-4.py-3.rounded-2xl.text-sm.font-medium.flex.items-center.gap-2(style="background:#d1fae5; color:#065f46; border:1px solid #a7f3d0")
        svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7")
        span= success[0]
    if error && error.length
      .mb-5.px-4.py-3.rounded-2xl.text-sm.font-medium.flex.items-center.gap-2(style="background:#fee2e2; color:#991b1b; border:1px solid #fecaca")
        svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12")
        span= error[0]

    //- ── FILTROS ─────────────────────────────────────────
    .bg-white.rounded-2xl.shadow-sm.border.border-gray-100.p-4.mb-5
      .flex.items-center.gap-3.flex-wrap
        //- Búsqueda
        .relative.flex-1(style="min-width:200px")
          svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute left-3 top-2.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z")
          input#buscarUsuario(
            type="text"
            placeholder="Buscar por nombre, apellido o correo..."
            class="w-full pl-9 pr-4 py-2 text-sm rounded-xl border border-gray-200 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:bg-white transition-colors"
            oninput="filtrar()"
          )

        //- Filtro rol
        select#filtroRol(
          class="text-sm border border-gray-200 rounded-xl px-3 py-2 bg-gray-50 text-gray-700 focus:outline-none focus:ring-2 focus:ring-emerald-400"
          onchange="filtrar()"
        )
          option(value="todos") Todos los roles
          option(value="organizador") Organizadores
          option(value="admin") Admins

        //- Filtro estado
        select#filtroEstado(
          class="text-sm border border-gray-200 rounded-xl px-3 py-2 bg-gray-50 text-gray-700 focus:outline-none focus:ring-2 focus:ring-emerald-400"
          onchange="filtrar()"
        )
          option(value="todos") Todos los estados
          option(value="activo") Activos
          option(value="inactivo") Inactivos

        //- Contador resultado
        span#contadorResultado.text-xs.text-gray-400

    //- ── TABLA ───────────────────────────────────────────
    .bg-white.rounded-2xl.shadow-sm.border.border-gray-100.overflow-hidden

      if !usuarios || usuarios.length === 0
        .p-16.text-center
          .h-14.w-14.rounded-2xl.bg-gray-100.flex.items-center.justify-center.mx-auto.mb-4
            svg(xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z")
          p.text-sm.text-gray-500 No hay usuarios registrados

      else
        .overflow-x-auto
          table#tablaUsuarios.w-full.text-sm(style="border-collapse:collapse")
            thead
              tr(style="background:#f9fafb; border-bottom:2px solid #f3f4f6")
                th.text-left.py-3.px-5(style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em") Usuario
                th.text-left.py-3.px-4(style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em") Correo
                th.text-center.py-3.px-4(style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em") Rol
                th.text-center.py-3.px-4(style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em") Estado
                th.text-center.py-3.px-4(style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em") Tandas
                th.text-left.py-3.px-4(style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em") Registro
                th.text-center.py-3.px-4(style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em") Acciones

            tbody#cuerpoTabla
              each u in usuarios
                tr.fila-usuario(
                  data-nombre=`${u.nombre} ${u.apellido}`.toLowerCase()
                  data-email=u.email.toLowerCase()
                  data-rol=u.rol
                  data-estado=u.activo ? 'activo' : 'inactivo'
                  class="hover:bg-gray-50 transition-colors"
                  style="border-bottom:1px solid #f9fafb"
                )
                  //- Usuario
                  td.py-3.px-5
                    .flex.items-center.gap-3
                      .h-9.w-9.rounded-xl.flex.items-center.justify-center.text-xs.font-bold.shrink-0(
                        style=`background:${u.activo ? '#dcfce7' : '#f3f4f6'}; color:${u.activo ? '#16a34a' : '#9ca3af'}`
                      )= (u.nombre.charAt(0) + u.apellido.charAt(0)).toUpperCase()
                      div
                        p.font-semibold.text-gray-800= `${u.nombre} ${u.apellido}`
                        p.text-xs.text-gray-400 ID ##{u.id}

                  //- Email
                  td.py-3.px-4
                    p.text-gray-700= u.email

                  //- Rol
                  td.py-3.px-4.text-center
                    span(
                      class=`text-xs font-semibold px-2 py-1 rounded-full ${u.rol === 'admin' ? 'bg-purple-100 text-purple-700' : 'bg-gray-100 text-gray-600'}`
                    )= u.rol.charAt(0).toUpperCase() + u.rol.slice(1)

                  //- Estado
                  td.py-3.px-4.text-center
                    if u.activo
                      span.text-xs.font-semibold.px-2.py-1.rounded-full(style="background:#dcfce7; color:#166534") Activo
                    else
                      span.text-xs.font-semibold.px-2.py-1.rounded-full(style="background:#fee2e2; color:#991b1b") Inactivo

                  //- Tandas
                  td.py-3.px-4.text-center
                    span.text-sm.font-bold.text-gray-700= u.total_tandas || 0

                  //- Registro
                  td.py-3.px-4
                    p.text-gray-600.text-xs= new Date(u.created_at).toLocaleDateString('es-MX', { day:'numeric', month:'short', year:'numeric' })
                    p.text-gray-400.text-xs= new Date(u.created_at).toLocaleTimeString('es-MX', { hour:'2-digit', minute:'2-digit' })

                  //- Acciones (no puede actuar sobre sí mismo)
                  td.py-3.px-4.text-center
                    if u.id === user.id
                      span.text-xs.text-gray-300 (tú)
                    else
                      .flex.items-center.justify-center.gap-2.flex-wrap

                        //- Cambiar Rol
                        form.inline-flex.items-center.gap-1(action=`/admin/usuarios/${u.id}/rol` method="POST")
                          select(
                            name="rol"
                            class="text-xs border border-gray-200 rounded-lg px-2 py-1 bg-gray-50 text-gray-700 focus:outline-none focus:ring-1 focus:ring-emerald-400"
                          )
                            option(value="organizador" selected=(u.rol === 'organizador')) Organizador
                            option(value="admin" selected=(u.rol === 'admin')) Admin
                          button(
                            type="submit"
                            class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-1 rounded-lg transition-colors hover:bg-blue-50 text-blue-600"
                            style="border:1px solid #bfdbfe"
                            title="Guardar rol"
                          )
                            svg(xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7")

                        //- Activar / Desactivar
                        if u.activo
                          form(action=`/admin/usuarios/${u.id}/desactivar` method="POST" onsubmit=`return confirm('¿Desactivar a ${u.nombre} ${u.apellido}?')`)
                            button(
                              type="submit"
                              class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-1 rounded-lg transition-colors hover:bg-amber-50 text-amber-600"
                              style="border:1px solid #fde68a"
                              title="Desactivar"
                            )
                              svg(xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636")
                        else
                          form(action=`/admin/usuarios/${u.id}/activar` method="POST")
                            button(
                              type="submit"
                              class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-1 rounded-lg transition-colors hover:bg-emerald-50 text-emerald-600"
                              style="border:1px solid #a7f3d0"
                              title="Activar"
                            )
                              svg(xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z")

                        //- Eliminar
                        form(action=`/admin/usuarios/${u.id}/eliminar` method="POST" onsubmit=`return confirm('⚠️ ¿Eliminar PERMANENTEMENTE a ${u.nombre} ${u.apellido}? Esta acción no se puede deshacer.')`)
                          button(
                            type="submit"
                            class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-1 rounded-lg transition-colors hover:bg-red-50 text-red-600"
                            style="border:1px solid #fecaca"
                            title="Eliminar"
                          )
                            svg(xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16")

        //- Sin resultados (oculto por defecto)
        #sinResultados.hidden.p-10.text-center
          p.text-sm.text-gray-400 No se encontraron usuarios con ese criterio.

block scripts
  script.
    const filas = document.querySelectorAll('.fila-usuario')
    const contador = document.getElementById('contadorResultado')

    function filtrar() {
      const texto  = document.getElementById('buscarUsuario').value.toLowerCase()
      const rol    = document.getElementById('filtroRol').value
      const estado = document.getElementById('filtroEstado').value
      let visibles = 0

      filas.forEach(fila => {
        const matchTexto  = fila.dataset.nombre.includes(texto) || fila.dataset.email.includes(texto)
        const matchRol    = rol    === 'todos' || fila.dataset.rol    === rol
        const matchEstado = estado === 'todos' || fila.dataset.estado === estado
        const visible = matchTexto && matchRol && matchEstado
        fila.style.display = visible ? '' : 'none'
        if (visible) visibles++
      })

      contador.textContent = `${visibles} resultado${visibles !== 1 ? 's' : ''}`
      document.getElementById('sinResultados').classList.toggle('hidden', visibles > 0)
    }

    // Inicializar contador
    filtrar()
