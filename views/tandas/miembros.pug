include ../layout/header.pug
include ../layout/navbar.pug
include ../layout/sidebar.pug 

block content
  main(class="ml-0 pt-24 px-6 pb-8 min-h-screen bg-gray-50 md:ml-64")

    //- ── HEADER ──────────────────────────────────────────
    div(class="mb-6")
      div(class="flex items-center gap-2 text-sm text-gray-400 mb-2")
        a(href="/tandas" class="hover:text-gray-600 transition-colors") Tandas
        span /
        span(class="text-gray-600 font-medium")= tanda.nombre
      p(class="text-sm text-gray-400 mt-1") Paso 2 de 3 — Agrega los #{tanda.total_miembros} miembros de la tanda

    //- ── PROGRESS STEPS ──────────────────────────────────
    div(class="flex items-center gap-0 mb-8 max-w-lg")
      div(class="flex items-center gap-2")
        div(class="w-8 h-8 rounded-full bg-emerald-500 text-white text-sm font-bold flex items-center justify-center")
          svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7")
        span(class="text-sm font-semibold text-emerald-600") Tanda
      div(class="flex-1 h-0.5 bg-emerald-500 mx-3")
      div(class="flex items-center gap-2")
        div(class="w-8 h-8 rounded-full bg-emerald-500 text-white text-sm font-bold flex items-center justify-center") 2
        span(class="text-sm font-semibold text-emerald-600") Miembros
      div(class="flex-1 h-0.5 bg-gray-200 mx-3")
      div(class="flex items-center gap-2")
        div(class="w-8 h-8 rounded-full bg-gray-200 text-gray-400 text-sm font-bold flex items-center justify-center") 3
        span(class="text-sm text-gray-400") Turnos

    //- ── FLASH ───────────────────────────────────────────
    if success && success.length
      div(class="bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-xl px-4 py-3 mb-4")= success
    if error && error.length
      div(class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3 mb-4")= error

    div(class="grid grid-cols-1 gap-6 lg:grid-cols-3")

      //- ── ADD MEMBER FORM ─────────────────────────────────
      if rondas && rondas.length > 0
         div(class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-center")
         p(class="text-sm font-semibold text-amber-700") Lista de miembros bloqueada
         p(class="text-xs text-amber-600 mt-1") El calendario ya fue generado. No se pueden agregar ni eliminar miembros.
         a(href=`/tandas/${tanda.id}` class="mt-3 inline-block text-sm text-emerald-600 font-medium hover:underline") Ver detalle de la tanda
      else
      div(class="lg:col-span-1")
        div(class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sticky top-24")
          h2(class="text-base font-semibold text-gray-800 mb-4") Agregar miembro
          
          //- Progress indicator
          div(class="mb-5")
            div(class="flex justify-between text-xs text-gray-400 mb-1")
              span Miembros agregados
              span #{miembros.length}/#{tanda.total_miembros}
            div(class="w-full bg-gray-100 rounded-full h-2")
              div(class="h-2 rounded-full bg-emerald-500 transition-all" style=`width:${Math.round((miembros.length/tanda.total_miembros)*100)}%`)

          if miembros.length >= tanda.total_miembros
            div(class="text-center py-4")
              div(class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-2")
                svg(xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7")
              p(class="text-sm font-semibold text-gray-700") ¡Tanda completa!
              p(class="text-xs text-gray-400 mt-1") Todos los miembros han sido agregados
          else
            form(action=`/tandas/${tanda.id}/miembros` method="POST" class="flex flex-col gap-4")
              input(type="hidden" name="_csrf" value=csrfToken)
              div(class="flex flex-col gap-1")
                label(for="nombre" class="text-sm font-semibold text-gray-700") Nombre
                input(
                  type="text"
                  id="nombre"
                  name="nombre"
                  placeholder="Nombre del miembro"
                  required
                  class="border border-gray-200 rounded-xl px-4 py-2 text-sm text-gray-800 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"
                )

              div(class="flex flex-col gap-1")
                label(for="telefono" class="text-sm font-semibold text-gray-700")
                  | Teléfono
                  span(class="text-gray-400 font-normal ml-1") (opcional)
                input(
                  type="tel"
                  id="telefono"
                  name="telefono"
                  placeholder="xxx-xxx-xxxx"
                  pattern="[0-9]{3}-[0-9]{3}-[0-9]{4}"
                  title="Formato válido: xxx-xxx-xxxx"
                  maxlength="12"
                  class="border border-gray-200 rounded-xl px-4 py-2 text-sm text-gray-800 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"
                )

              div(class="flex flex-col gap-1")
                label(for="notas" class="text-sm font-semibold text-gray-700")
                  | Notas
                  span(class="text-gray-400 font-normal ml-1") (opcional)
                input(
                  type="text"
                  id="notas"
                  name="notas"
                  placeholder="Ej: Hermana, compañera de trabajo..."
                  class="border border-gray-200 rounded-xl px-4 py-2 text-sm text-gray-800 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"
                )

              button(
                type="submit"
                class="w-full bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-semibold py-2 rounded-xl transition-colors"
              ) Agregar miembro

          //- Next step button (only show when tanda is full)
          if miembros.length >= tanda.total_miembros
            a(
              href=`/tandas/${tanda.id}/turnos`
              class="mt-4 w-full inline-flex items-center justify-center gap-2 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-semibold py-3 rounded-xl transition-colors"
            )
              | Continuar a turnos
              svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7")
          else
            p(class="text-xs text-gray-400 text-center mt-4") Agrega #{tanda.total_miembros - miembros.length} miembro(s) más para continuar

      //- ── MEMBERS LIST ────────────────────────────────────
      div(class="lg:col-span-2")
        div(class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden")
          div(class="px-6 py-4 border-b border-gray-100")
            h2(class="text-base font-semibold text-gray-800") Miembros agregados
            p(class="text-xs text-gray-400 mt-0.5") Los turnos se asignarán en el siguiente paso

          if miembros.length === 0
            div(class="flex flex-col items-center justify-center py-16 text-center")
              div(class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mb-3")
                svg(xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z")
              p(class="text-sm text-gray-400") Aún no hay miembros
          else
            ul(class="divide-y divide-gray-50")
              each miembro, index in miembros
                li(class="flex items-center justify-between px-6 py-4")
                  div(class="flex items-center gap-3")
                    div(class="w-9 h-9 rounded-full bg-emerald-100 text-emerald-700 text-sm font-bold flex items-center justify-center flex-shrink-0")
                      = miembro.nombre.charAt(0).toUpperCase()
                    div
                      p(class="text-sm font-semibold text-gray-800")= miembro.nombre
                      p(class="text-xs text-gray-400")= miembro.telefono || 'Sin teléfono'
                  div(class="flex items-center gap-3")
                    if miembro.notas
                      span(class="text-xs text-gray-400 italic")= miembro.notas
                    form(action=`/tandas/${tanda.id}/miembros/${miembro.id}/delete` method="POST")
                      input(type="hidden" name="_csrf" value=csrfToken)
                      button(type="submit" class="text-red-400 hover:text-red-600 transition-colors p-1")
                        svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16")

block scripts
  script.
    // ── PHONE FORMATTING ─────────────────────────────────
    document.querySelectorAll('input[type="tel"]').forEach(input => {
      input.addEventListener('input', function(e) {
              let cleaned = e.target.value.replace(/[^0-9]/g, '');
        let match = cleaned.match(/^([0-9]{0,3})([0-9]{0,3})([0-9]{0,4})/);
        if (match) {
          e.target.value = !match[2] ? match[1] : match[1] + '-' + match[2] + (match[3] ? '-' + match[3] : '');
        } else {
          e.target.value = cleaned;
        }
      });
      // Evitar que ingrese letras
      input.addEventListener('keypress', function(e) {
        if (!/[0-9]/.test(e.key) && e.key !== 'Backspace' && e.key !== 'Tab' && e.key !== 'Delete' && !e.ctrlKey && !e.metaKey && e.key.length === 1) {
          e.preventDefault();
        }
      });
    });
