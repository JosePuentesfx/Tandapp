include layout/header.pug

block content
  div(class="min-h-screen bg-emerald-100 flex items-center justify-center px-4 py-10")
    div(class="bg-white rounded-2xl shadow-sm border border-emerald-200 w-full max-w-md px-6 py-10 text-center")
      div(class="text-6xl mb-4") ⚠️
      h1(class="text-2xl font-bold text-gray-800 mb-4")= pageTitle || 'Error'
      p(class="text-gray-600 mb-8")= message || 'Algo salió mal.'
      a(href="/" class="inline-block bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 px-6 rounded-lg text-sm transition") Volver al inicio
