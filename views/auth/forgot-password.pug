include ../layout/header.pug
block content
  main.min-h-screen.flex.items-center.justify-center.px-4.py-10(class="bg-emerald-100")

    div(class="w-full max-w-md bg-white rounded-2xl shadow-sm border border-emerald-200 p-8")
      .mb-6
        a(href="/login" class="text-sm text-gray-400 hover:underline mb-4 inline-block") ← Volver a Iniciar Sesión
        h1.text-2xl.font-bold.text-emerald-900.mt-2 Recuperar contraseña
        p.text-sm.text-gray-500.mt-1 Te enviaremos un código de seguridad a tu correo para restablecer tu cuenta.

      if error && error.length
        .mb-5.px-4.py-3.rounded-2xl.text-sm.font-medium.flex.items-center.gap-2(style="background:#fee2e2;color:#991b1b;border:1px solid #fecaca")
          svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12")
          span= error[0]

      //- Ícono
      .flex.justify-center.mb-6
        .h-16.w-16.rounded-2xl.flex.items-center.justify-center(style="background:#ecfdf5")
          svg(xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")

      form(action="/forgot-password" method="POST")
        input(type="hidden" name="_csrf" value=csrfToken)
        div.mb-6
          label.block.my-2(for='email') Correo electrónico
          input#email(
            class="rounded-sm mb-2 w-full inset-shadow-2xs ring ring-black/20 placeholder:opacity-90 px-2 py-2 text-sm"
            type='email'
            name="email"
            required
            placeholder="tu@correo.com"
          )

        button(
          type="submit"
          class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 rounded-lg text-sm transition mt-1"
        )
          | Enviar código →
      
      p.text-xs.text-gray-400.text-center.mt-4 El código expira en 10 minutos
