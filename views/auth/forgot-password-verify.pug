include ../layout/header.pug
block content
  main.min-h-screen.flex.items-center.justify-center.px-4.py-10(class="bg-emerald-100")

    div(class="w-full max-w-md bg-white rounded-2xl shadow-sm border border-emerald-200 p-8")
      .mb-6
        a(href="/forgot-password" class="text-sm text-gray-400 hover:underline mb-4 inline-block") ← Volver
        h1.text-2xl.font-bold.text-emerald-900.mt-2 Ingresa el código
        p.text-sm.text-gray-500.mt-1 Revisa tu correo y escribe el código de 6 dígitos

      if success && success.length
        .mb-5.px-4.py-3.rounded-2xl.text-sm.font-medium.flex.items-center.gap-2(style="background:#d1fae5;color:#065f46;border:1px solid #a7f3d0")
          svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7")
          span= success[0]
      if error && error.length
        .mb-5.px-4.py-3.rounded-2xl.text-sm.font-medium.flex.items-center.gap-2(style="background:#fee2e2;color:#991b1b;border:1px solid #fecaca")
          svg(xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12")
          span= error[0]

      .flex.justify-center.mb-6
        .h-16.w-16.rounded-2xl.flex.items-center.justify-center(style="background:#f0fdf4")
          svg(xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")

      h2.text-base.font-semibold.text-gray-900.text-center.mb-1 Código enviado
      p.text-sm.text-gray-500.text-center.mb-8
        | Revisa 
        strong.text-gray-700= email
        |  e ingresa el código

      form(action="/reset-password/verificar" method="POST")
        input(type="hidden" name="_csrf" value=csrfToken)
        //- Input de 6 dígitos estilizado
        .mb-6
          input#codigoInput(
            type="text"
            name="codigo"
            maxlength="6"
            placeholder="000000"
            required
            autocomplete="one-time-code"
            oninput="this.value=this.value.replace(/[^0-9]/g,'')"
            class="w-full text-center text-3xl font-bold tracking-widest py-4 rounded-xl border-2 border-gray-200 bg-gray-50 text-gray-900 focus:outline-none focus:border-emerald-400 focus:bg-white transition-colors"
            style="letter-spacing:0.3em"
          )
          p.text-xs.text-gray-400.text-center.mt-2 Solo números, 6 dígitos

        button(
          type="submit"
          class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 rounded-lg text-sm transition mt-1"
        )
          | Verificar código

      //- Reenviar
      .text-center.mt-5
        p.text-xs.text-gray-400
          | ¿No llegó el código?
          a(href="/forgot-password" class="text-emerald-600 font-medium ml-1 hover:underline") Reenviar

block scripts
  script.
    // Auto-focus y avance automático al completar 6 dígitos
    const input = document.getElementById('codigoInput')
    input.focus()
    input.addEventListener('input', () => {
      if (input.value.length === 6) {
        input.closest('form').submit()
      }
    })
