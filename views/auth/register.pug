include ../layout/header.pug
block content
  //- Light gray full page background
  div(class="min-h-screen bg-emerald-100 flex items-center justify-center px-4 py-10")

    //- White card — same style as login
    div(class="bg-white rounded-2xl shadow-sm border border-emerald-200 w-full max-w-md px-6 py-10")

      //- ── LOGO + TITLE ───────────────────────────────
      div(class="flex flex-col items-center mb-8")
        a.flex.items-center.gap-3.min-w-0(href="/homepage")
          img.h-9.w-9.shrink-0(src="/img/tandapp.png", alt="Logo TandApp")
          span.text-xl.font-bold.text-emerald-900.tracking-wide TANDAPP
        p(class="text-slate-500 text-sm mt-1") Crea tu cuenta para empezar

      //- ── ERROR FLASH ────────────────────────────────
      if error && error.length
        div(class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-5")
          = error

      //- ── FORM ───────────────────────────────────────
      form(action="/register" method="POST" class="flex flex-col gap-5")
        input(type="hidden" name="_csrf" value=csrfToken)

        //- Nombre + Apellido side by side
        div(class="flex gap-3")
          div(class="flex flex-col gap-1 flex-1")
            label(for="nombre" class="text-sm font-medium text-slate-700") Nombre
            input(
              type="text"
              id="nombre"
              name="nombre"
              placeholder="María"
              required
              class="border border-gray-300 rounded-lg px-4 py-3 text-sm text-slate-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"
            )

          div(class="flex flex-col gap-1 flex-1")
            label(for="apellido" class="text-sm font-medium text-slate-700") Apellido
            input(
              type="text"
              id="apellido"
              name="apellido"
              placeholder="García"
              required
              class="border border-gray-300 rounded-lg px-4 py-3 text-sm text-slate-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"
            )

        //- Email
        div(class="flex flex-col gap-1")
          label(for="email" class="text-sm font-medium text-slate-700") Correo electrónico
          input(
            type="email"
            id="email"
            name="email"
            placeholder="tu@correo.com"
            required
            class="border border-gray-300 rounded-lg px-4 py-3 text-sm text-slate-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"
          )

        //- Password
        div(class="flex flex-col gap-1")
          label(for="password" class="text-sm font-medium text-slate-700") Contraseña
          div(class="relative")
            input(
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-slate-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition pr-11"
            )
            button(type="button" onclick="togglePassword('password', 'eyeIcon1')" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600")
              svg(id="eyeIcon1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5")
                path(stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z")
                path(stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z")

        //- Confirm Password
        div(class="flex flex-col gap-1")
          label(for="confirmPassword" class="text-sm font-medium text-slate-700") Confirmar contraseña
          div(class="relative")
            input(
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="••••••••"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-slate-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition pr-11"
            )
            button(type="button" onclick="togglePassword('confirmPassword', 'eyeIcon2')" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600")
              svg(id="eyeIcon2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5")
                path(stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z")
                path(stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z")

        //- Submit button — same dark navy as login
        button(
          type="submit"
          class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 rounded-lg text-sm transition mt-1"
        ) Crear Cuenta

      //- ── BOTTOM LINK ────────────────────────────────
      div(class='text-center text-sm text-slate-500 mt-6')
        p ¿Ya tienes cuenta?
        a(href="/login" class="font-semibold text-emerald-800 hover:text-emerald-600 transition") Inicia sesión
        p ó
        a(href="/homepage" class="font-semibold text-emerald-800 hover:text-emerald-600 transition") Regresar a inicio.
//- ── TOGGLE PASSWORD SCRIPT ─────────────────────────
block scripts
  script.
    function togglePassword(inputId, iconId) {
      const input = document.getElementById(inputId)
      const icon = document.getElementById(iconId)
      if (input.type === 'password') {
        input.type = 'text'
        icon.innerHTML = `
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
        `
      } else {
        input.type = 'password'
        icon.innerHTML = `
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
        `
      }
    }
